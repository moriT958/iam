---

---

<div class="prose">
  <slot />
</div>

<style>
  .prose {
    margin-top: 22px;
    color: var(--text);
    font-size: 15px;
    line-height: 1.85;
    max-width: 100%;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  .prose :global(p) {
    margin-top: 18px;
  }

  .prose :global(p:first-child) {
    margin-top: 0;
  }

  .prose :global(h2) {
    font-size: 20px;
    color: var(--fg);
    margin-top: 32px;
    margin-bottom: 8px;
    line-height: 1.3;
    border-bottom: 1px solid var(--border);
    padding-bottom: 6px;
    scroll-margin-top: 72px;
  }

  .prose :global(h3) {
    font-size: 17px;
    color: var(--fg);
    margin-top: 28px;
    margin-bottom: 6px;
    line-height: 1.3;
    border-bottom: 1px solid var(--border);
    padding-bottom: 4px;
    scroll-margin-top: 72px;
  }

  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    color: var(--fg);
    margin-top: 24px;
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .prose :global(a) {
    color: var(--blue);
    text-decoration: underline;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin-top: 18px;
  }

  .prose :global(li) {
    margin-top: 6px;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--border-strong);
    padding-left: 16px;
    color: var(--muted);
    margin: 18px 0 0;
  }

  .prose :global(code) {
    font-size: 13px;
    font-family: inherit;
  }

  .prose :global(:not(pre) > code) {
    background: var(--panel2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 5px;
  }

  .prose :global(.code-wrapper) {
    position: relative;
    margin-top: 18px;
    max-width: 100%;
  }

  .prose :global(pre) {
    background: var(--panel2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 18px;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 0;
    font-size: 13px;
    line-height: 1.65;
    white-space: pre;
    word-break: normal;
    overflow-wrap: normal;
    -webkit-text-size-adjust: 100%;
    text-size-adjust: 100%;
    font-family: inherit;
  }

  .prose :global(.copy-btn) {
    position: absolute;
    top: 10px;
    right: 12px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 5px;
    color: var(--muted);
    font-size: 11px;
    padding: 3px 8px;
    cursor: pointer;
    font-family: inherit;
  }

  .prose :global(.copy-btn:hover) {
    color: var(--fg);
    border-color: var(--border-strong);
  }

  .prose :global(.copy-btn.copied) {
    color: var(--accent);
    border-color: var(--accent);
  }

  .prose :global(pre code) {
    display: block;
    width: max-content;
    min-width: 100%;
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    overflow-wrap: normal;
    word-break: normal;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin-top: 28px;
  }

  .prose :global(strong) {
    color: var(--fg);
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 6px;
    margin-top: 18px;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-top: 18px;
    font-size: 14px;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .prose :global(th) {
    border: 1px solid var(--border);
    padding: 8px 12px;
    background: var(--panel);
    color: var(--fg);
  }

  .prose :global(td) {
    border: 1px solid var(--border);
    padding: 8px 12px;
  }

  /* hljs syntax theme */
  .prose :global(.hljs-keyword),
  .prose :global(.hljs-operator),
  .prose :global(.hljs-punctuation) {
    color: var(--code-keyword);
  }

  .prose :global(.hljs-string),
  .prose :global(.hljs-template-string),
  .prose :global(.hljs-regexp) {
    color: var(--code-string);
  }

  .prose :global(.hljs-title),
  .prose :global(.hljs-title.function_),
  .prose :global(.hljs-title.class_) {
    color: var(--code-func);
  }

  .prose :global(.hljs-number),
  .prose :global(.hljs-literal) {
    color: var(--purple);
  }

  .prose :global(.hljs-comment) {
    color: var(--dim);
    font-style: italic;
  }

  .prose :global(.hljs-variable),
  .prose :global(.hljs-attr) {
    color: var(--text);
  }

  .prose :global(.hljs-built_in),
  .prose :global(.hljs-type) {
    color: var(--teal);
  }
</style>

<script>
  document.querySelectorAll<HTMLPreElement>(".prose pre").forEach((pre) => {
    const wrapper = document.createElement("div");
    wrapper.className = "code-wrapper";
    pre.parentNode!.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const btn = document.createElement("button");
    btn.type = "button";
    btn.className = "copy-btn";
    btn.setAttribute("aria-label", "Copy code");
    btn.textContent = "Copy";
    wrapper.appendChild(btn);

    btn.addEventListener("click", () => {
      const code = pre.textContent ?? "";
      navigator.clipboard.writeText(code).then(() => {
        btn.textContent = "Copied!";
        btn.classList.add("copied");
        setTimeout(() => {
          btn.textContent = "Copy";
          btn.classList.remove("copied");
        }, 1500);
      });
    });
  });
</script>
