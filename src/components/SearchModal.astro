---
import { getCollection } from "astro:content";
import searchIconRaw from "../assets/search-icon.svg?raw";

const allPosts = await getCollection("posts");
const searchPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((p) => ({
    slug: p.id,
    date: p.data.date.toISOString().slice(0, 10),
    title: p.data.title,
    excerpt: p.data.description ?? "",
    tags: p.data.tags ?? [],
    url: p.data.url ?? null,
  }));
---

<button type="button" id="search-btn" aria-label="Search">
  <span set:html={searchIconRaw} />
  <span class="shortcut-label">⌘K</span>
</button>

<div id="search-overlay" style="display:none">
  <div id="search-panel" role="dialog" aria-modal="true" aria-label="Search">
    <div class="input-row">
      <span set:html={searchIconRaw} />
      <input
        id="search-input"
        type="text"
        placeholder="Search posts..."
        autocomplete="off"
        spellcheck="false"
      />
      <button type="button" id="search-clear" aria-label="Clear">✕</button>
      <span class="esc-hint">esc</span>
    </div>
    <div id="search-results"></div>
    <div class="search-footer">
      <span>↑↓ navigate</span>
      <span>↵ open</span>
      <span>esc close</span>
    </div>
  </div>
</div>

<script define:vars={{ searchPosts }} is:inline>
  const overlay = document.getElementById("search-overlay");
  const panel = document.getElementById("search-panel");
  const input = document.getElementById("search-input");
  const clearBtn = document.getElementById("search-clear");
  const resultsEl = document.getElementById("search-results");
  const searchBtn = document.getElementById("search-btn");

  if (!overlay || !panel || !input || !clearBtn || !resultsEl || !searchBtn)
    return;

  // portal: position:fixed inside a backdrop-filter parent breaks stacking context
  document.body.appendChild(overlay);

  let isOpen = false;
  let query = "";
  let selectedIdx = 0;

  const getResults = () => {
    const q = query.trim().toLowerCase();
    if (!q) return searchPosts.slice(0, 6);
    return searchPosts.filter(
      (p) =>
        p.title.toLowerCase().includes(q) ||
        p.excerpt.toLowerCase().includes(q) ||
        p.tags.some((t) => t.toLowerCase().includes(q)),
    );
  };

  const esc = (s) =>
    String(s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");

  const highlight = (text) => {
    const q = query.trim();
    if (!q) return esc(text);
    const re = new RegExp(
      `(${q.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")})`,
      "gi",
    );
    return esc(text).replace(re, '<mark class="search-hl">$1</mark>');
  };

  const setActive = (idx) => {
    selectedIdx = idx;
    [...resultsEl.querySelectorAll(".result-item")].forEach((el, i) =>
      el.classList.toggle("active", i === idx),
    );
    resultsEl
      .querySelector(".result-item.active")
      ?.scrollIntoView({ block: "nearest" });
  };

  // 結果一覧の再構築
  // 検索ワードが変わったときだけ呼ぶ
  const render = () => {
    clearBtn.style.display = query ? "block" : "none";

    const results = getResults();

    if (results.length === 0) {
      resultsEl.innerHTML = `<div class="result-empty">No results for "<span style="color:var(--fg)">${esc(query)}</span>"</div>`;
      return;
    }

    resultsEl.innerHTML = results
      .map((p, i) => {
        const href = p.url ?? `/posts/${p.slug}`;
        const tags = p.tags
          .map((tg) => `<span class="result-tag">#${esc(tg)}</span>`)
          .join("");
        return `<div class="result-item${i === 0 ? " active" : ""}" data-href="${esc(href)}">
          <div class="result-title">${highlight(p.title)}</div>
          <div class="result-meta"><span>${p.date}</span>${tags}</div>
        </div>`;
      })
      .join("");

    selectedIdx = 0;
  };

  // イベント委譲: resultsEl 単体にまとめる
  resultsEl.addEventListener("click", (e) => {
    const item = e.target.closest(".result-item");
    if (!item) return;
    closeModal();
    window.location.href = item.dataset.href;
  });

  resultsEl.addEventListener("mousemove", (e) => {
    const item = e.target.closest(".result-item");
    if (!item) return;
    const items = [...resultsEl.querySelectorAll(".result-item")];
    setActive(items.indexOf(item));
  });

  const openModal = () => {
    isOpen = true;
    query = "";
    selectedIdx = 0;
    input.value = "";
    overlay.style.display = "flex";
    document.body.style.overflow = "hidden";
    render();
    setTimeout(() => input.focus(), 30);
  };

  const closeModal = () => {
    isOpen = false;
    overlay.style.display = "none";
    document.body.style.overflow = "";
  };

  searchBtn.addEventListener("click", openModal);

  overlay.addEventListener("click", (e) => {
    if (e.target === overlay) closeModal();
  });

  panel.addEventListener("click", (e) => e.stopPropagation());

  input.addEventListener("input", () => {
    const newQuery = input.value;
    if (newQuery !== query) {
      query = newQuery;
      selectedIdx = 0;
      render();
    }
  });

  clearBtn.addEventListener("click", () => {
    query = "";
    input.value = "";
    input.focus();
    selectedIdx = 0;
    render();
  });

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      isOpen ? closeModal() : openModal();
      return;
    }
    if (!isOpen) return;

    const results = getResults();
    if (e.key === "Escape") {
      closeModal();
    } else if (e.key === "ArrowDown" || (e.ctrlKey && e.key === "n")) {
      e.preventDefault();
      setActive(Math.min(selectedIdx + 1, results.length - 1));
    } else if (e.key === "ArrowUp" || (e.ctrlKey && e.key === "p")) {
      e.preventDefault();
      setActive(Math.max(selectedIdx - 1, 0));
    } else if (e.key === "Enter") {
      const post = results[selectedIdx];
      if (post) {
        closeModal();
        window.location.href = post.url ?? `/posts/${post.slug}`;
      }
    }
  });
</script>

<style>
  #search-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 8px;
    padding: 5px 10px;
    font-family: inherit;
    font-size: 12px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-right: 8px;
    transition:
      color 0.12s,
      border-color 0.12s;
  }

  #search-btn:hover {
    color: var(--fg);
    border-color: var(--border-strong);
  }

  .shortcut-label {
    color: var(--dim);
    font-size: 11px;
  }

  #search-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--search-overlay-bg);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    align-items: flex-start;
    justify-content: center;
    padding-top: 60px;
  }

  #search-panel {
    width: 560px;
    max-width: 90%;
    background: var(--search-panel-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.08),
      0 8px 32px -8px rgba(0, 0, 0, 0.2);
    overflow: hidden;
  }

  .input-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--border);
  }

  #search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--fg);
    font-family: inherit;
    font-size: 14px;
    caret-color: var(--accent);
  }

  #search-input::placeholder {
    color: var(--muted);
  }

  #search-clear {
    background: transparent;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 12px;
    font-family: inherit;
    padding: 0;
    line-height: 1;
    display: none;
  }

  .esc-hint {
    color: var(--dim);
    font-size: 11px;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 6px;
    flex-shrink: 0;
  }

  #search-results {
    max-height: 360px;
    overflow-y: auto;
  }

  .search-footer {
    padding: 8px 18px;
    display: flex;
    gap: 14px;
    color: var(--dim);
    font-size: 11px;
  }

  :global(.result-item) {
    display: block;
    padding: 12px 18px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    background: transparent;
    transition: background 0.1s;
  }

  :global(.result-item.active) {
    background: var(--hover-bg);
  }

  :global(.result-title) {
    color: var(--fg);
    font-size: 14px;
    font-weight: 500;
  }

  :global(.result-meta) {
    color: var(--muted);
    font-size: 12px;
    margin-top: 3px;
    display: flex;
    gap: 10px;
  }

  :global(.result-tag) {
    color: var(--teal);
  }

  :global(.result-empty) {
    padding: 24px 18px;
    color: var(--muted);
    font-size: 13px;
    text-align: center;
  }

  :global(mark.search-hl) {
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 2px;
  }
</style>
