---
type TocItem = {
  id: string;
  text: string;
  depth: number;
};

type Props = {
  items: TocItem[];
};

const { items } = Astro.props;
---

<nav class="toc" aria-label="目次">
  <p class="toc-label">On this page</p>
  <ul class="toc-list">
    {
      items.map((item) => (
        <li>
          <a
            href={`#${item.id}`}
            class={item.depth === 3 ? "toc-link toc-link-h3" : "toc-link"}
          >
            {item.text}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .toc {
    position: fixed;
    top: 72px;
    width: 220px;
    max-height: calc(100vh - 90px);
    overflow-y: auto;
    padding-right: 4px;
  }

  .toc-label {
    margin: 0 0 10px;
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .toc-list {
    list-style: none;
    padding: 0 0 0 12px;
    margin: 0;
    border-left: 1px solid var(--border);
  }

  .toc-link {
    display: block;
    font-size: 12px;
    color: var(--muted);
    text-decoration: none;
    padding: 4px 0;
    line-height: 1.45;
  }

  .toc-link-h3 {
    color: var(--dim);
    padding: 3px 0 3px 12px;
  }

  .toc-link:hover {
    color: var(--fg);
  }
</style>

<script>
  const aside = document.querySelector<HTMLElement>(".toc-aside");
  const nav = document.querySelector<HTMLElement>(".toc");

  if (!nav) throw new Error();

  if (aside) {
    const sync = () => {
      nav.style.left = aside.getBoundingClientRect().left + "px";
    };
    sync();
    window.addEventListener("resize", sync, { passive: true });
  }

  const anchors = new Map<string, HTMLAnchorElement>();
  nav.querySelectorAll<HTMLAnchorElement>("a[href^='#']").forEach((a) => {
    const id = (a.getAttribute("href") ?? "").slice(1);
    if (id) anchors.set(id, a);
  });

  const ids = Array.from(anchors.keys());
  let current = "";

  const setActive = (id: string) => {
    if (id === current) return;
    const prev = anchors.get(current);
    if (prev) prev.style.removeProperty("color");
    const next = anchors.get(id);
    if (next) next.style.setProperty("color", "var(--teal)");
    current = id;
  };

  const update = () => {
    const offset = 88;
    let best = ids[0];
    for (const id of ids) {
      const el = document.getElementById(id);
      if (el && el.getBoundingClientRect().top < offset) {
        best = id;
      }
    }
    if (best) setActive(best);
  };

  let raf = 0;
  window.addEventListener(
    "scroll",
    () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        update();
        raf = 0;
      });
    },
    { passive: true },
  );

  update();
</script>
