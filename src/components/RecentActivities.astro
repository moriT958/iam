---
type Activity = {
  date: string;
  title: string;
  href: string;
};

type Props = {
  items: Activity[];
};

const { items } = Astro.props;
---

<section class="recent-activities">
  <div class="title-row">
    <h2 class="title">
      <span class="title-icon">$</span>
      <span>Recent activities</span>
    </h2>
  </div>
  <div class="list" id="activity-list">
    {
      items.length === 0 ? (
        <p class="empty">直近の活動はありません。</p>
      ) : (
        items.map((item) => (
          <a href={item.href} class="activity-item">
            <span class="date">{item.date}</span>
            <span class="item-title">{item.title}</span>
          </a>
        ))
      )
    }
  </div>
</section>

<style>
  .recent-activities {
    margin-top: 36px;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .title {
    margin: 0;
    color: var(--fg);
    font-size: 15px;
    font-weight: 600;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }

  .title-icon {
    color: var(--accent);
    font-size: 14px;
  }

  .list {
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .activity-item {
    display: grid;
    grid-template-columns: 94px 1fr;
    gap: 14px;
    padding: 10px 4px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--fg);
    border-radius: 4px;
  }

  .activity-item:hover {
    background: var(--hover-bg);
  }

  .date {
    color: var(--muted);
    font-size: 12px;
    padding-top: 2px;
  }

  .item-title {
    color: var(--fg);
    font-size: 14px;
  }

  .empty {
    color: var(--muted);
    font-size: 13px;
    padding: 12px 4px;
  }
</style>
