---
import type { Activity } from "../types";

type Props = {
  items: Activity[];
  visibleNum: number;
};

const { items, visibleNum } = Astro.props;
const hasMore = items.length > visibleNum;
---

<section class="recent-activities">
  <div class="title-row">
    <h2 class="title">
      <span class="title-icon">$</span>
      <span>Recent activities</span>
    </h2>
  </div>
  <div class="list" id="activity-list">
    {
      items.length === 0 ? (
        <p class="empty">直近の活動はありません。</p>
      ) : (
        items.map((item, i) => (
          <a
            href={item.href}
            class="activity-item"
            data-index={i}
            style={i >= visibleNum ? "display:none" : ""}
          >
            <span class="date">{item.date}</span>
            <span class="item-title">{item.title}</span>
          </a>
        ))
      )
    }
  </div>
  {
    hasMore && (
      <div class="more-wrap">
        <button id="show-more" type="button">
          more
        </button>
      </div>
    )
  }
</section>

<script>
  document.getElementById("show-more")?.addEventListener("click", () => {
    document
      .querySelectorAll("#activity-list .activity-item")
      .forEach((el) => ((el as HTMLElement).style.display = ""));
    document.getElementById("show-more")?.parentElement?.remove();
  });
</script>

<style>
  .recent-activities {
    margin-top: 36px;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .title {
    margin: 0;
    color: var(--fg);
    font-size: 15px;
    font-weight: 600;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }

  .title-icon {
    color: var(--accent);
    font-size: 14px;
  }

  .list {
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .activity-item {
    display: grid;
    grid-template-columns: 94px 1fr;
    gap: 14px;
    padding: 10px 4px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--fg);
    border-radius: 4px;
  }

  .activity-item:hover {
    background: var(--hover-bg);
  }

  .date {
    color: var(--muted);
    font-size: 12px;
    padding-top: 2px;
  }

  .item-title {
    color: var(--fg);
    font-size: 14px;
  }

  .empty {
    color: var(--muted);
    font-size: 13px;
    padding: 12px 4px;
  }

  .more-wrap {
    margin-top: 12px;
    text-align: center;
  }

  #show-more {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 12px;
    padding: 4px 18px;
    border-radius: 999px;
    cursor: pointer;
  }

  #show-more:hover {
    color: var(--fg);
    border-color: var(--border-strong);
  }
</style>
