---
import moonIconRaw from "../assets/moon-icon.svg?raw";
import sunIconRaw from "../assets/sun-icon.svg?raw";

type Props = {
  activePage: "home" | "posts" | "archives";
};

const { activePage } = Astro.props;
---

<header>
  <a href="/" class="brand">
    <span class="brand-icon">$</span>
    <span>morit958.com</span>
  </a>
  <nav>
    <a href="/" class={activePage === "home" ? "nav-link active" : "nav-link"}
      >Home</a
    >
    <a
      href="/posts"
      class={activePage === "posts" ? "nav-link active" : "nav-link"}>Posts</a
    >
    <a
      href="/archives"
      class={activePage === "archives" ? "nav-link active" : "nav-link"}
    >
      Archives
    </a>
  </nav>
  <div class="spacer"></div>
  <button type="button" id="theme-toggle" aria-label="Switch theme">
    <span class="moon-icon" set:html={moonIconRaw} />
    <span class="sun-icon" set:html={sunIconRaw} />
  </button>
</header>

<script>
  const btn = document.getElementById("theme-toggle")!;
  const COOKIE = "var-card-theme";

  btn.addEventListener("click", () => {
    const current = document.documentElement.dataset.theme ?? "light";
    const next = current === "light" ? "dark" : "light";
    document.documentElement.dataset.theme = next;
    document.cookie = `${COOKIE}=${next}; Path=/; Max-Age=31536000; SameSite=Lax`;
  });
</script>

<style>
  header {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 14px 36px;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 30%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .brand {
    text-decoration: none;
    color: var(--fg);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.3px;
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }

  .brand-icon {
    color: var(--accent);
  }

  nav {
    display: flex;
    gap: 14px;
    margin-left: 18px;
  }

  .nav-link {
    color: var(--muted);
    font-size: 13px;
    padding: 6px 4px;
    text-decoration: none;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover {
    color: var(--fg);
  }

  .nav-link.active {
    color: var(--fg);
    border-bottom: 2px solid var(--accent);
  }

  .spacer {
    flex: 1;
  }

  #theme-toggle {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 999px;
    width: 34px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  #theme-toggle:hover {
    color: var(--fg);
    border-color: var(--border-strong);
  }

  .moon-icon {
    display: inline-flex;
  }

  .sun-icon {
    display: none;
  }

  :global([data-theme="dark"]) .moon-icon {
    display: none;
  }

  :global([data-theme="dark"]) .sun-icon {
    display: inline-flex;
  }

  @media (max-width: 640px) {
    header {
      padding: 12px 16px;
      gap: 10px;
    }

    nav {
      display: none;
    }
  }
</style>
