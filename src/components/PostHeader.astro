---
type Props = {
  title: string;
  date: Date;
  tags?: string[];
};

const { title, date, tags = [] } = Astro.props;
---

<a href="/posts" class="back-link">← Posts</a>

<div class="meta">{date.toISOString().slice(0, 10)}</div>

<h1 class="title">{title}</h1>

<div class="tag-row">
  {
    tags.map((tag) => (
      <a href={`/tags/${tag}`} class="tag">
        <span class="tag-hash">#</span>
        {tag}
      </a>
    ))
  }
</div>

<style>
  .back-link {
    color: var(--muted);
    font-size: 12px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.12s;
  }

  .back-link:hover {
    color: var(--fg);
  }

  .meta {
    color: var(--muted);
    font-size: 12px;
    margin-top: 24px;
  }

  .title {
    margin: 6px 0 10px;
    color: var(--fg);
    font-size: 28px;
    line-height: 1.35;
    letter-spacing: -0.4px;
    font-weight: 700;
    overflow-wrap: anywhere;
  }

  .tag-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tag {
    color: var(--teal);
    font-size: 12px;
    border-bottom: 1px dashed var(--teal);
    padding-bottom: 1px;
    text-decoration: none;
  }

  .tag-hash {
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .title {
      font-size: 22px;
    }
  }
</style>
