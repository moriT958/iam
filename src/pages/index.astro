---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import HeroCard from "../components/HeroCard.astro";
import RecentActivities from "../components/RecentActivities.astro";
import Footer from "../components/Footer.astro";

const profile = {
  user: "Morita Kohei",
  handle: "moriT958",
  role: "Student SWE · 鹿児島",
  bio: "鹿児島大学の M2 大学院生です。Web 技術に興味があります。好きな言語は Go です。",
  links: [
    {
      label: "GitHub",
      url: "github.com/moriT958",
      href: "https://github.com/moriT958",
    },
    { label: "X", url: "@morita_kagshm", href: "https://x.com/morita_kagshm" },
    { label: "RSS", url: "/rss.xml", href: "/rss.xml" },
  ],
};

const allPosts = await getCollection(
  "posts",
  ({ data }) => import.meta.env.DEV || !data.draft,
);
const now = new Date();
const activities = allPosts
  .filter(
    (p) =>
      p.data.date.getFullYear() === now.getFullYear() &&
      p.data.date.getMonth() === now.getMonth(),
  )
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((p) => ({
    date: p.data.date.toISOString().slice(0, 10),
    title: p.data.title,
    href: p.data.url ?? `/posts/${p.id}`,
  }));
---

<Layout
  title="morita's website"
  description="morit958 のウェブサイト。鹿児島の大学院生。Web や技術に関することを書きます。"
  ogType="website"
  ogImage="/images/morit958.webp"
>
  <main class="page">
    <Header activePage="home" />
    <div class="content-wrap">
      <HeroCard {...profile} />
      <RecentActivities items={activities} />
    </div>
    <Footer />
  </main>
</Layout>

<style>
  .page {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    display: grid;
    grid-template-rows: auto 1fr auto;
  }

  .content-wrap {
    padding: 36px 36px 48px;
    max-width: 820px;
    margin: 0 auto;
    width: 100%;
  }

  @media (max-width: 640px) {
    .content-wrap {
      padding: 24px 16px 40px;
    }
  }
</style>
