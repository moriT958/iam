---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PostHeader from "../../components/PostHeader.astro";
import Prose from "../../components/Prose.astro";
import PostNav from "../../components/PostNav.astro";
import TableOfContents from "../../components/TableOfContents.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const sorted = posts
    .filter((p) => !p.data.url)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return sorted.map((post, i) => {
    const prevPost = sorted[i + 1] ?? null;
    const nextPost = sorted[i - 1] ?? null;
    return { params: { id: post.id }, props: { post, prevPost, nextPost } };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const tocItems = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({ id: h.slug, text: h.text, depth: h.depth }));
const hasToc = tocItems.length > 0;
---

<Layout
  title={`${post.data.title} | morita's website`}
  description={post.data.description ?? post.data.title}
>
  <main class="page">
    <Header activePage="posts" />
    <div class={hasToc ? "content-with-toc" : "content"}>
      <article class={hasToc ? "article-wide" : "article"}>
        <PostHeader
          title={post.data.title}
          date={post.data.date}
          tags={post.data.tags}
        />
        <Prose>
          <Content />
        </Prose>
        <PostNav prevPost={prevPost} nextPost={nextPost} />
      </article>
      {
        hasToc && (
          <aside class="toc-aside">
            <TableOfContents items={tocItems} />
          </aside>
        )
      }
    </div>
    <Footer />
  </main>
</Layout>

<style>
  .page {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    display: grid;
    grid-template-rows: auto 1fr auto;
    overflow-x: clip;
  }

  .content {
    padding: 0;
    width: 100%;
    min-width: 0;
  }

  .content-with-toc {
    display: grid;
    grid-template-columns: minmax(0, 800px) 220px;
    column-gap: 48px;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 36px;
    box-sizing: border-box;
    width: 100%;
  }

  .article {
    padding: 28px 36px 60px;
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    min-width: 0;
    box-sizing: border-box;
  }

  .article-wide {
    padding: 28px 0 60px;
    min-width: 0;
    overflow-x: clip;
  }

  .toc-aside {
    padding-top: 28px;
  }

  @media (max-width: 1080px) {
    .content-with-toc {
      grid-template-columns: 1fr;
      padding: 0 16px;
    }

    .toc-aside {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .article {
      padding: 20px 16px 48px;
    }

    .article-wide {
      padding: 20px 0 48px;
    }
  }
</style>
