---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const sorted = posts.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );
  return sorted.map((post, i) => {
    const prevPost = sorted.slice(i + 1).find((p) => !p.data.url) ?? null;
    const nextPost = sorted.slice(0, i).findLast((p) => !p.data.url) ?? null;
    return { params: { id: post.id }, props: { post, prevPost, nextPost } };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} | morita's website`}
  description={post.data.description ?? post.data.title}
>
  <main class="page">
    <Header activePage="posts" />
    <div class="content">
      <article class="article">
        <a href="/posts" class="back-link">← Posts</a>

        <div class="meta">{post.data.date.toISOString().slice(0, 10)}</div>

        <h1 class="title">
          {post.data.title}
          {post.data.url && <span class="external-mark">↗</span>}
        </h1>

        <div class="tag-row">
          {
            (post.data.tags ?? []).map((tag) => (
              <a href={`/tags/${tag}`} class="tag">
                <span class="tag-hash">#</span>
                {tag}
              </a>
            ))
          }
        </div>

        {
          !post.data.url && (
            <div class="prose">
              <Content />
            </div>
          )
        }

        <div class="prev-next">
          {
            prevPost ? (
              <a href={`/posts/${prevPost.id}`} class="prev-card">
                <div class="nav-label">← 前の記事</div>
                <div class="nav-title">{prevPost.data.title}</div>
              </a>
            ) : (
              <div />
            )
          }
          {
            nextPost ? (
              <a href={`/posts/${nextPost.id}`} class="next-card">
                <div class="nav-label">次の記事 →</div>
                <div class="nav-title">{nextPost.data.title}</div>
              </a>
            ) : (
              <div />
            )
          }
        </div>
      </article>
    </div>
    <Footer />
  </main>
</Layout>

<style>
  .page {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    display: grid;
    grid-template-rows: auto 1fr auto;
  }

  .content {
    padding: 0;
    width: 100%;
    min-width: 0;
  }

  .article {
    padding: 28px 36px 60px;
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    min-width: 0;
    box-sizing: border-box;
  }

  .back-link {
    color: var(--muted);
    font-size: 12px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.12s;
  }

  .back-link:hover {
    color: var(--fg);
  }

  .meta {
    color: var(--muted);
    font-size: 12px;
    margin-top: 24px;
  }

  .title {
    margin: 6px 0 10px;
    color: var(--fg);
    font-size: 28px;
    line-height: 1.35;
    letter-spacing: -0.4px;
    font-weight: 700;
    overflow-wrap: anywhere;
  }

  .external-mark {
    color: var(--muted);
    margin-left: 5px;
    font-size: 18px;
  }

  .tag-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tag {
    color: var(--teal);
    font-size: 12px;
    border-bottom: 1px dashed var(--teal);
    padding-bottom: 1px;
    text-decoration: none;
  }

  .tag-hash {
    opacity: 0.7;
  }

  /* prose */
  .prose {
    margin-top: 22px;
    color: var(--text);
    font-size: 15px;
    line-height: 1.85;
    max-width: 100%;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  .prose :global(p) {
    margin-top: 18px;
  }

  .prose :global(p:first-child) {
    margin-top: 0;
  }

  .prose :global(h2) {
    font-size: 20px;
    color: var(--fg);
    margin-top: 32px;
    margin-bottom: 8px;
    line-height: 1.3;
    border-bottom: 1px solid var(--border);
    padding-bottom: 6px;
    scroll-margin-top: 72px;
  }

  .prose :global(h3) {
    font-size: 17px;
    color: var(--fg);
    margin-top: 28px;
    margin-bottom: 6px;
    line-height: 1.3;
    border-bottom: 1px solid var(--border);
    padding-bottom: 4px;
    scroll-margin-top: 72px;
  }

  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    color: var(--fg);
    margin-top: 24px;
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .prose :global(a) {
    color: var(--blue);
    text-decoration: underline;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin-top: 18px;
  }

  .prose :global(li) {
    margin-top: 6px;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--border-strong);
    padding-left: 16px;
    color: var(--muted);
    margin: 18px 0 0;
  }

  .prose :global(code) {
    font-size: 13px;
    font-family: inherit;
  }

  .prose :global(:not(pre) > code) {
    background: var(--panel2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 5px;
  }

  .prose :global(pre) {
    background: var(--panel2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-top: 18px;
    font-size: 13px;
    line-height: 1.6;
    white-space: pre;
    word-break: normal;
    overflow-wrap: normal;
  }

  .prose :global(pre code) {
    display: block;
    width: max-content;
    min-width: 100%;
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    overflow-wrap: normal;
    word-break: normal;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin-top: 28px;
  }

  .prose :global(strong) {
    color: var(--fg);
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 6px;
    margin-top: 18px;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-top: 18px;
    font-size: 14px;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .prose :global(th) {
    border: 1px solid var(--border);
    padding: 8px 12px;
    background: var(--panel);
    color: var(--fg);
  }

  .prose :global(td) {
    border: 1px solid var(--border);
    padding: 8px 12px;
  }

  /* prev / next */
  .prev-next {
    margin-top: 36px;
    padding-top: 18px;
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .prev-card,
  .next-card {
    padding: 14px;
    background: var(--panel);
    border-radius: 8px;
    border: 1px solid var(--border);
    color: var(--fg);
    text-decoration: none;
    transition: border-color 0.12s;
  }

  .prev-card:hover,
  .next-card:hover {
    border-color: var(--border-strong);
  }

  .next-card {
    text-align: right;
  }

  .nav-label {
    color: var(--muted);
    font-size: 11px;
  }

  .nav-title {
    font-size: 13px;
    margin-top: 3px;
    overflow-wrap: anywhere;
  }

  @media (max-width: 640px) {
    .article {
      padding: 20px 16px 48px;
    }

    .title {
      font-size: 22px;
    }

    .prev-next {
      grid-template-columns: 1fr;
    }
  }

  /* hljs syntax theme — mapped to ayu CSS variables */
  .prose :global(.hljs-keyword),
  .prose :global(.hljs-operator),
  .prose :global(.hljs-punctuation) {
    color: var(--code-keyword);
  }

  .prose :global(.hljs-string),
  .prose :global(.hljs-template-string),
  .prose :global(.hljs-regexp) {
    color: var(--code-string);
  }

  .prose :global(.hljs-title),
  .prose :global(.hljs-title.function_),
  .prose :global(.hljs-title.class_) {
    color: var(--code-func);
  }

  .prose :global(.hljs-number),
  .prose :global(.hljs-literal) {
    color: var(--purple);
  }

  .prose :global(.hljs-comment) {
    color: var(--dim);
    font-style: italic;
  }

  .prose :global(.hljs-variable),
  .prose :global(.hljs-attr) {
    color: var(--text);
  }

  .prose :global(.hljs-built_in),
  .prose :global(.hljs-type) {
    color: var(--teal);
  }
</style>
