---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PostHeader from "../../components/PostHeader.astro";
import Prose from "../../components/Prose.astro";
import PostNav from "../../components/PostNav.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const sorted = posts
    .filter((p) => !p.data.url)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return sorted.map((post, i) => {
    const prevPost = sorted[i + 1] ?? null;
    const nextPost = sorted[i - 1] ?? null;
    return { params: { id: post.id }, props: { post, prevPost, nextPost } };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} | morita's website`}
  description={post.data.description ?? post.data.title}
>
  <main class="page">
    <Header activePage="posts" />
    <div class="content">
      <article class="article">
        <PostHeader
          title={post.data.title}
          date={post.data.date}
          tags={post.data.tags}
        />
        <Prose>
          <Content />
        </Prose>
        <PostNav prevPost={prevPost} nextPost={nextPost} />
      </article>
    </div>
    <Footer />
  </main>
</Layout>

<style>
  .page {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    display: grid;
    grid-template-rows: auto 1fr auto;
  }

  .content {
    padding: 0;
    width: 100%;
    min-width: 0;
  }

  .article {
    padding: 28px 36px 60px;
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    min-width: 0;
    box-sizing: border-box;
  }

  @media (max-width: 640px) {
    .article {
      padding: 20px 16px 48px;
    }
  }
</style>
