---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection(
    "posts",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );
  const tagSet = new Set(allPosts.flatMap((p) => p.data.tags ?? []));
  return Array.from(tagSet).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter((p) => p.data.tags?.includes(tag))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Layout
  title={`#${tag} | morita's website`}
  description={`"#${tag}" タグの記事一覧。`}
>
  <main class="page">
    <Header activePage="posts" />
    <div class="content-wrap">
      <div class="heading-wrap">
        <div class="heading">
          <span class="prompt">$</span>
          <span class="muted"> grep -rl </span>
          <span class="flag">"#{tag}"</span>
          <span class="muted"> posts/</span>
        </div>
        <div class="subhead">
          <span>
            {posts.length} posts tagged <span class="tag-accent">#{tag}</span>
          </span>
          <span>·</span>
          <a href="/posts" class="back-link">← all posts</a>
        </div>
      </div>

      <div class="list">
        {
          posts.map((post) => {
            const href = post.data.url ?? `/posts/${post.id}`;
            const isExternal = !!post.data.url;
            return (
              <div class="post-item">
                <a
                  href={href}
                  target={isExternal ? "_blank" : undefined}
                  rel={isExternal ? "noopener noreferrer" : undefined}
                  class="card-overlay"
                />
                <div class="post-meta">
                  <span>{post.data.date.toISOString().slice(0, 10)}</span>
                </div>
                <h3 class="post-title">
                  {post.data.title}
                  {isExternal && <span class="external-mark">↗</span>}
                </h3>
                {post.data.description && (
                  <p class="post-excerpt">{post.data.description}</p>
                )}
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="tag-row">
                    {post.data.tags.map((tg) => (
                      <a href={`/tags/${tg}`} class="tag">
                        <span class="tag-hash">#</span>
                        {tg}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            );
          })
        }
      </div>
    </div>
    <Footer />
  </main>
</Layout>

<style>
  .page {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    display: grid;
    grid-template-rows: auto 1fr auto;
  }

  .content-wrap {
    padding: 32px 36px 48px;
    max-width: 820px;
    margin: 0 auto;
    width: 100%;
  }

  /* --- Heading --- */
  .heading-wrap {
    border-bottom: 1px solid var(--border);
    padding-bottom: 14px;
    margin-bottom: 4px;
  }

  .heading {
    font-size: 22px;
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.3px;
  }

  .prompt {
    color: var(--accent);
  }

  .muted {
    color: var(--muted);
  }

  .flag {
    color: var(--accent);
  }

  .subhead {
    color: var(--muted);
    font-size: 12px;
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tag-accent {
    color: var(--teal);
  }

  .back-link {
    color: var(--muted);
    text-decoration: none;
    font-size: 12px;
  }

  .back-link:hover {
    color: var(--fg);
  }

  /* --- Post list --- */
  .list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    position: relative;
    padding: 18px 8px;
    border-bottom: 1px solid var(--border);
    border-radius: 6px;
  }

  .post-item:hover {
    background: var(--hover-bg);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--muted);
    font-size: 12px;
  }

  .post-title {
    margin: 6px 0;
    color: var(--fg);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.2px;
  }

  .external-mark {
    color: var(--muted);
    margin-left: 5px;
    font-size: 13px;
  }

  .post-excerpt {
    margin: 0;
    color: var(--text);
    font-size: 13px;
    line-height: 1.7;
  }

  .tag-row {
    margin-top: 10px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tag {
    position: relative;
    color: var(--teal);
    font-size: 12px;
    border-bottom: 1px dashed var(--teal);
    padding-bottom: 1px;
    text-decoration: none;
  }

  .tag-hash {
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .content-wrap {
      padding: 20px 16px 40px;
    }
  }
</style>
